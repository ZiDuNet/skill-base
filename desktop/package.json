{
  "name": "skill-base-desktop",
  "version": "0.1.0",
  "description": "Skill Base Desktop — 本地 Agent Skill 管理客户端",
  "homepage": "https://skillbase.reaidea.com",
  "author": {
    "name": "ginuim",
    "email": "ginuim@users.noreply.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ginuim/skill-base.git"
  },
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "vite build && electron-builder",
    "dist:mac": "vite build && electron-builder --mac dmg",
    "dist:win": "vite build && electron-builder --win nsis",
    "dist:linux": "vite build && electron-builder --linux AppImage deb"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild"]
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.skillbase.desktop",
    "productName": "Skill Base",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../cli/lib",
        "to": "cli-lib"
      }
    ],
    "asar": true,
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.developer-tools",
      "identity": null
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development",
      "executableName": "skill-base-desktop",
      "maintainer": "ginuim <ginuim@users.noreply.github.com>"
    }
  }
}
