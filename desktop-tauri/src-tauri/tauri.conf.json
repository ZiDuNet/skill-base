{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skill Base",
  "version": "0.1.0",
  "identifier": "com.skillbase.desktop.tauri",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "node scripts/prepare-resources.mjs && vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Skill Base",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/bridge/*",
      "resources/node/bin/*"
    ]
  },
  "plugins": {}
}
